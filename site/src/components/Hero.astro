---
export interface Props {
	image?: string;
	title?: string;
	subtitle?: string;
}

const { image = '/images/2016/04/Background-1.jpg', title, subtitle } = Astro.props;
---

<section
	class="relative w-full h-[640px] flex bg-center bg-cover"
	style={`background-image: url('${image}');`}
>
	<div class="relative z-10 w-full flex items-center justify-center px-6">
		<div class="max-w-[640px] border border-white/80 bg-slate-950/75 p-7 text-center shadow-xl backdrop-blur-[2px] sm:p-9">
			<h1 class="text-white text-[30px] leading-snug font-semibold drop-shadow">
				{title}
			</h1>
			{subtitle && <p class="text-white/95 text-[17px] mt-4">{subtitle}</p>}
		</div>
	</div>

	<div class="absolute z-10 left-0 right-0 bottom-16 flex items-center justify-center gap-8">
		<a
			href="/fitmus-product/"
			class="bg-[#e03420] border-2 border-[#e03420] text-white uppercase font-semibold tracking-[0.2em] px-10 py-3 text-[13px] hover:bg-[#c0291b] hover:border-[#c0291b] transition"
		>
			View All Fitmus Product
		</a>
		<a
			href="/contact-us/"
			class="border-2 border-white text-white uppercase font-semibold tracking-[0.2em] px-10 py-3 text-[13px] hover:bg-white hover:text-[#e03420] transition"
		>
			Contact Us
		</a>
	</div>
</section>
