---
const categories = [
  {
    title: 'Weight Lifting Equipment',
    slug: 'weight-lifting-equipment',
    description: 'Barbells, plates, dumbbells and kettlebells for progressive strength work.',
  },
  {
    title: 'Body Weight & Gymnastic',
    slug: 'body-weight-gymnastic',
    description: 'Rings, bars, straps and accessories for bodyweight and gymnastic training.',
  },
  {
    title: 'Strength & Condition',
    slug: 'strength-condition',
    description: 'Benches, boxes, bands and training tools for functional conditioning.',
  },
  {
    title: 'Crossfit Racks & Rigs',
    slug: 'crossfit-racks-rigs',
    description: 'Modular rigs, racks and pull-up stations for demanding group sessions.',
  },
  {
    title: 'Strongman Equipment',
    slug: 'strongman-equipment',
    description: 'Sleds, logs, sandbags and carries built for strongman-style training.',
  },
  {
    title: 'Equipment Storage',
    slug: 'equipment-storage',
    description: 'Practical racks and holders to keep training spaces organised and safe.',
  },
  {
    title: 'Balance & Mobility',
    slug: 'balance-mobility',
    description: 'Mobility, recovery and balance tools for warm-ups and daily movement.',
  },
  {
    title: 'Cardio Equipment & Accessories',
    slug: 'cardio-equipment-accessories',
    description: 'Ropes, bikes and conditioning accessories for complete cardio sessions.',
  },
];

const youtubeUrl = 'https://www.youtube.com/channel/UC8gP2tvfEjAcItWFf3eacyg/videos?view_as=subscriber';
---

<section class="bg-slate-50 px-6 py-16 md:py-20" aria-labelledby="catalogue-heading">
	<div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
		<div>
			<p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#e03420]">Fitmus resources</p>
			<h2 id="catalogue-heading" class="mt-3 text-3xl font-bold text-slate-900 md:text-4xl">Plan your next training space</h2>
			<p class="mt-4 max-w-2xl text-base leading-7 text-slate-600">
				Browse the current Fitmus range in one downloadable catalogue, then explore practical training ideas from our video channel.
			</p>
			<div class="mt-7 flex flex-wrap gap-3">
				<a href="/Fitmus-Product-catalog.pdf" download class="inline-flex items-center rounded-full bg-[#e03420] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#b9291a] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#e03420]">
					Download product catalogue
				</a>
				<a href={youtubeUrl} target="_blank" rel="noreferrer" class="inline-flex items-center rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-800 transition hover:border-[#e03420] hover:text-[#e03420] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#e03420]">
					Watch Fitmus videos <span class="ml-2" aria-hidden="true">↗</span>
				</a>
			</div>
		</div>
		<div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
			<p class="text-sm font-semibold text-slate-900">What the catalogue includes</p>
			<ul class="mt-4 grid gap-3 text-sm leading-6 text-slate-600 sm:grid-cols-2">
				<li>• Strength and conditioning equipment</li>
				<li>• CrossFit rigs and racks</li>
				<li>• Storage and gym accessories</li>
				<li>• Mobility and cardio ranges</li>
			</ul>
		</div>
	</div>
</section>

<section class="px-6 py-16 md:py-20" aria-labelledby="category-guide-heading">
	<div class="mx-auto max-w-7xl">
		<div class="max-w-2xl">
			<p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#e03420]">Explore by training goal</p>
			<h2 id="category-guide-heading" class="mt-3 text-3xl font-bold text-slate-900 md:text-4xl">Find the right equipment range</h2>
			<p class="mt-4 text-base leading-7 text-slate-600">Start with a category to compare equipment for your facility, programme or next workout.</p>
		</div>
		<div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
			{categories.map((category) => (
				<a href={`/products/${category.slug}/`} class="group rounded-2xl border border-slate-200 bg-white p-5 transition hover:-translate-y-0.5 hover:border-[#e03420] hover:shadow-md focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#e03420]">
					<h3 class="text-lg font-semibold text-slate-900 group-hover:text-[#e03420]">{category.title}</h3>
					<p class="mt-2 text-sm leading-6 text-slate-600">{category.description}</p>
					<span class="mt-4 inline-block text-sm font-semibold text-[#e03420]">View range <span aria-hidden="true">→</span></span>
				</a>
			))}
		</div>
	</div>
</section>
