---
import { getCollection } from 'astro:content';
import { latestProductSlugs, selectContentEntries } from '../lib/homepage-content';

const latestProducts = selectContentEntries(
  await getCollection('products'),
  latestProductSlugs,
  'Latest Products',
);
const news = (await getCollection('posts'))
  .sort((a, b) => {
    const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
    const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
    return dateB - dateA;
  })
  .slice(0, 8);
---

<section class="py-20 bg-white">
	<div class="max-w-7xl mx-auto px-6">
		<div class="grid md:grid-cols-3 gap-12">
			<div class="md:col-span-2">
				<h2 class="text-3xl font-bold text-gray-900 mb-8">Latest Products</h2>
				<div class="grid grid-cols-2 sm:grid-cols-3 gap-6">
					{
						latestProducts.map((p) => (
							<a
								href={`/product/${p.id}/`}
								class="group block bg-white rounded-lg shadow-md hover:shadow-lg transition"
							>
								<div class="aspect-square overflow-hidden rounded-t-lg">
									<img
										src={p.data.featuredImage || '/images/2016/02/favicon-200.png'}
										alt={p.data.title}
										class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
										loading="lazy"
									/>
								</div>
								<div class="p-4">
									<h3 class="font-semibold text-gray-900 text-sm line-clamp-2">{p.data.title}</h3>
								</div>
							</a>
						))
					}
				</div>
			</div>

			<div>
				<h2 class="text-3xl font-bold text-gray-900 mb-8">In the News</h2>
				<ul class="space-y-6">
					{
						news.map((n) => (
							<li>
								<a href={`/${n.id}/`} class="group block">
									<h3 class="font-semibold text-gray-900 group-hover:text-[#e03420] transition mb-2">
										{n.data.title}
									</h3>
									<p class="text-sm text-gray-500">{n.data.date}</p>
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</div>
</section>
