---
import { getCollection } from 'astro:content';
import {
  footerProductSlugs,
  newsPostSlugs,
  selectContentEntries,
} from '../lib/homepage-content';

const recentWorks = selectContentEntries(
  await getCollection('products'),
  footerProductSlugs,
  'Footer Recent Works',
);
const news = selectContentEntries(await getCollection('posts'), newsPostSlugs, 'Footer News');

const categories = [
  { name: 'Weight Lifting Equipment', url: '/products/weight-lifting-equipment/' },
  { name: 'Body Weight & Gymnastic', url: '/products/body-weight-gymnastic/' },
  { name: 'Strength & Condition', url: '/products/strength-condition/' },
  { name: 'Crossfit Racks & Rigs', url: '/products/crossfit-racks-rigs/' },
  { name: 'Strongman Equipment', url: '/products/strongman-equipment/' },
  { name: 'Equipment Storage', url: '/products/equipment-storage/' },
  { name: 'Balance & Mobility', url: '/products/balance-mobility/' },
  { name: 'Cardio Equipment & Accessories', url: '/products/cardio-equipment-accessories/' },
];
---

<footer class="bg-slate-100 py-16 text-slate-900">
	<div class="max-w-7xl mx-auto px-6">
		<div class="grid grid-cols-2 md:grid-cols-4 gap-8">
			<div>
				<h3 class="text-lg font-bold mb-6">Recent Works</h3>
				<div class="grid grid-cols-5 gap-2">
					{
						recentWorks.slice(0, 10).map((w) => (
							<a
								href={`/product/${w.id}/`}
								class="aspect-square rounded overflow-hidden bg-white hover:ring-2 hover:ring-[#e03420] transition"
							>
								<img
									src={w.data.featuredImage || '/images/2016/02/favicon-200.png'}
									alt={w.data.title}
									class="w-full h-full object-cover"
									loading="lazy"
								/>
							</a>
						))
					}
				</div>
			</div>

			<div>
				<h3 class="text-lg font-bold mb-6">In the News</h3>
				<ul class="space-y-4">
					{
						news.map((n) => (
							<li>
								<a href={`/${n.id}/`} class="block group">
									<div class="flex items-start gap-2">
										<i class="fas fa-chevron-right text-[#e03420] text-xs mt-2"></i>
										<div>
							<h4 class="text-sm text-slate-800 group-hover:text-[#e03420] transition leading-tight">
											{n.data.title}
											</h4>
							<p class="text-xs text-slate-500 mt-1">{n.data.date}</p>
										</div>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<div>
				<h3 class="text-lg font-bold mb-6">Product Category</h3>
				<ul class="space-y-3">
					{
						categories.map((c) => (
							<li>
								<a href={c.url} class="flex items-center gap-2 text-sm hover:text-[#e03420] transition">
									<i class="fas fa-chevron-right text-[#e03420] text-xs"></i>
									<span>{c.name}</span>
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<div>
				<img
					src="/images/2018/11/logo-sport-s.png"
					alt="Fitmus Logo"
					class="h-10 mb-6"
				/>
				<p class="text-sm text-slate-600 mb-2">Rizhao Fitmus Sporting Goods Co.Ltd</p>
				<p class="text-sm text-slate-600 mb-2">
					Add: Wulian County Industrial Area, Rizhao, Shandong Province, China 262300
				</p>
				<p class="text-sm text-slate-600 mb-2">
					Tel: +86 15963097328 Fax: +86 633 5889298
				</p>
				<p class="text-sm text-slate-600 mb-6">
					Email: <a href="mailto:info@fitmus-sport.com" class="hover:text-[#e03420]">info@fitmus-sport.com</a>
				</p>
				<a
					href="https://www.youtube.com/channel/UC8gP2tvfEjAcItWFf3eacyg/videos?view_as=subscriber"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2 bg-[#e03420] text-white px-6 py-3 rounded hover:bg-[#c0291b] transition"
				>
					<i class="fab fa-youtube"></i>
					<span>WATCH THE VIDEO NOW</span>
				</a>
			</div>
		</div>

		<div class="border-t border-slate-300 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
			<p class="text-sm text-slate-500">
				Copyright 2026 <a href="/" class="hover:text-[#e03420]">Fitmus</a> | All Rights Reserved
			</p>
			<div class="flex gap-4">
				<a
					href="https://www.facebook.com/Fitmussport/"
					target="_blank"
					rel="noopener noreferrer"
					class="w-10 h-10 rounded-full bg-white text-slate-700 flex items-center justify-center hover:bg-[#e03420] hover:text-white transition"
					aria-label="Facebook"
				>
					<i class="fab fa-facebook-f"></i>
				</a>
				<a
					href="https://www.linkedin.com/company/fitmus-sport/"
					target="_blank"
					rel="noopener noreferrer"
					class="w-10 h-10 rounded-full bg-white text-slate-700 flex items-center justify-center hover:bg-[#e03420] hover:text-white transition"
					aria-label="LinkedIn"
				>
					<i class="fab fa-linkedin-in"></i>
				</a>
				<a
					href="https://www.youtube.com/channel/UC8gP2tvfEjAcItWFf3eacyg/"
					target="_blank"
					rel="noopener noreferrer"
					class="w-10 h-10 rounded-full bg-white text-slate-700 flex items-center justify-center hover:bg-[#e03420] hover:text-white transition"
					aria-label="YouTube"
				>
					<i class="fab fa-youtube"></i>
				</a>
				<a
					href="https://www.instagram.com/fitmus_sport/"
					target="_blank"
					rel="noopener noreferrer"
					class="w-10 h-10 rounded-full bg-white text-slate-700 flex items-center justify-center hover:bg-[#e03420] hover:text-white transition"
					aria-label="Instagram"
				>
					<i class="fab fa-instagram"></i>
				</a>
			</div>
		</div>
	</div>
</footer>
