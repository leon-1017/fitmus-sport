---
import { getCollection } from 'astro:content';
import { featuredProductSlugs, selectContentEntries } from '../lib/homepage-content';

const products = selectContentEntries(
  await getCollection('products'),
  featuredProductSlugs,
  'Featured Products',
);
---

<section class="py-16 bg-gray-50">
	<div class="max-w-7xl mx-auto px-6">
		<h2 class="text-3xl font-bold text-center mb-12">Featured Products</h2>
		<div class="relative">
			<div class="flex overflow-x-auto gap-6 pb-4 snap-x snap-mandatory">
				{
					products.map((p) => (
						<a
							href={`/product/${p.id}/`}
							class="flex-shrink-0 w-72 bg-white rounded-lg shadow-md hover:shadow-lg transition group"
						>
							<div class="aspect-square overflow-hidden rounded-t-lg">
								<img
									src={p.data.featuredImage || '/images/2016/02/favicon-200.png'}
									alt={p.data.title}
									class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
									loading="lazy"
								/>
							</div>
							<div class="p-4">
								<h3 class="font-semibold text-gray-900 text-sm line-clamp-2">{p.data.title}</h3>
							</div>
						</a>
					))
				}
			</div>
			<button
				class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 bg-white/90 rounded-full shadow-lg flex items-center justify-center hover:bg-white transition"
				aria-label="Previous"
			>
				<i class="fas fa-chevron-left text-gray-700"></i>
			</button>
			<button
				class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 bg-white/90 rounded-full shadow-lg flex items-center justify-center hover:bg-white transition"
				aria-label="Next"
			>
				<i class="fas fa-chevron-right text-gray-700"></i>
			</button>
		</div>
	</div>
</section>
