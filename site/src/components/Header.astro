---
const categoryMap: Record<string, string> = {
  'weight-lifting-equipment': 'Weight Lifting Equipment',
  'body-weight-gymnastic': 'Body Weight & Gymnastic',
  'strength-condition': 'Strength & Condition',
  'crossfit-racks-rigs': 'Crossfit Racks & Rigs',
  'strongman-equipment': 'Strongman Equipment',
  'equipment-storage': 'Equipment Storage',
  'balance-mobility': 'Balance & Mobility',
  'cardio-equipment-accessories': 'Cardio Equipment & Accessories',
};

const categorySlugs = Object.keys(categoryMap);
const primaryNav = [
  { label: 'Home', href: '/' },
  { label: 'About Fitmus', href: '/about-fitmus/' },
  { label: 'Fitmus Product', href: '/fitmus-product/', hasSubmenu: true },
  { label: 'In the News', href: '/in-the-news/' },
  { label: 'Contact Us', href: '/contact-us/' },
];
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/95 text-slate-900 shadow-sm backdrop-blur">
	<div class="mx-auto max-w-7xl px-4">
		<div class="flex h-[76px] items-center justify-between gap-6">
			<a href="/" class="shrink-0 rounded focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#e03420]">
				<img src="/images/2018/11/logo-sport-s.png" alt="Fitmus Sport" class="h-11 w-auto" />
			</a>

			<nav class="hidden items-center gap-1 lg:flex" aria-label="Primary navigation">
				<ul class="flex items-center gap-1">
					{
						primaryNav.map((item) =>
							item.hasSubmenu ? (
								<li class="group relative">
									<a
										href={item.href}
										class="inline-flex items-center gap-1 rounded px-3 py-2 text-sm font-semibold uppercase tracking-[0.08em] text-slate-700 transition hover:bg-slate-100 hover:text-[#e03420] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#e03420]"
									>
										{item.label}
										<span aria-hidden="true" class="text-base leading-none">⌄</span>
									</a>
									<div class="absolute left-0 top-full z-50 hidden w-[560px] border border-slate-200 bg-white p-3 shadow-xl group-hover:block group-focus-within:block">
										<div class="mb-2 border-b border-slate-100 px-3 pb-2 text-xs font-bold uppercase tracking-[0.12em] text-slate-500">
											Fitmus Product Categories
										</div>
										<ul class="grid grid-cols-2 gap-1">
											{categorySlugs.map((slug) => (
												<li>
													<a
														href={`/products/${slug}/`}
														class="block rounded px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-[#e03420] focus-visible:bg-slate-100 focus-visible:text-[#e03420] focus-visible:outline-none"
													>
														{categoryMap[slug]}
													</a>
												</li>
											))}
										</ul>
									</div>
								</li>
							) : (
								<li>
									<a
										href={item.href}
										class="rounded px-3 py-2 text-sm font-semibold uppercase tracking-[0.08em] text-slate-700 transition hover:bg-slate-100 hover:text-[#e03420] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#e03420]"
									>
										{item.label}
									</a>
								</li>
							),
						)
					}
				</ul>
			</nav>
		</div>

		<nav class="-mx-4 border-t border-slate-200 lg:hidden" aria-label="Mobile primary navigation">
			<div class="flex gap-1 overflow-x-auto px-4 py-2">
				<a
					href="/"
					class="shrink-0 rounded px-3 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 hover:text-[#e03420] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#e03420]"
				>
					Home
				</a>
				<a
					href="/about-fitmus/"
					class="shrink-0 rounded px-3 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 hover:text-[#e03420] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#e03420]"
				>
					About Fitmus
				</a>
				<details class="group relative shrink-0">
					<summary class="flex cursor-pointer list-none items-center gap-1 rounded px-3 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 hover:text-[#e03420] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#e03420] [&::-webkit-details-marker]:hidden">
						Fitmus Product <span aria-hidden="true">⌄</span>
					</summary>
					<div class="absolute left-0 top-full z-50 mt-1 w-[min(28rem,calc(100vw-2rem))] border border-slate-200 bg-white p-3 shadow-xl">
						<a
							href="/fitmus-product/"
							class="mb-2 block rounded border-b border-slate-100 px-3 py-2 text-sm font-semibold text-[#e03420] focus-visible:bg-slate-100 focus-visible:outline-none"
						>
							View Fitmus Product
						</a>
						<ul class="grid grid-cols-2 gap-1">
							{categorySlugs.map((slug) => (
								<li>
									<a
										href={`/products/${slug}/`}
										class="block rounded px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-[#e03420] focus-visible:bg-slate-100 focus-visible:text-[#e03420] focus-visible:outline-none"
									>
										{categoryMap[slug]}
									</a>
								</li>
							))}
						</ul>
					</div>
				</details>
				<a
					href="/in-the-news/"
					class="shrink-0 rounded px-3 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 hover:text-[#e03420] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#e03420]"
				>
					In the News
				</a>
				<a
					href="/contact-us/"
					class="shrink-0 rounded px-3 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 hover:text-[#e03420] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#e03420]"
				>
					Contact Us
				</a>
			</div>
		</nav>
	</div>
</header>
