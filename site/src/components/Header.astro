---
const categoryMap: Record<string, string> = {
  'weight-lifting-equipment': 'Weight Lifting Equipment',
  'body-weight-gymnastic': 'Body Weight & Gymnastic',
  'strength-condition': 'Strength & Condition',
  'crossfit-racks-rigs': 'Crossfit Racks & Rigs',
  'strongman-equipment': 'Strongman Equipment',
  'equipment-storage': 'Equipment Storage',
  'balance-mobility': 'Balance & Mobility',
  'cardio-equipment-accessories': 'Cardio Equipment & Accessories',
};

const categorySlugs = Object.keys(categoryMap);
const primaryNav = [
  { label: 'Home', href: '/' },
  { label: 'About Fitmus', href: '/about-fitmus/' },
  { label: 'In the News', href: '/in-the-news/' },
  { label: 'Contact Us', href: '/contact-us/' },
];

const navLinkClasses =
  'rounded px-3 py-2 text-sm font-semibold uppercase tracking-[0.08em] text-slate-700 transition hover:bg-slate-100 hover:text-[#e03420] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#e03420]';
const submenuLinkClasses =
  'block rounded px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-[#e03420] focus-visible:bg-slate-100 focus-visible:text-[#e03420] focus-visible:outline-none';
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/95 text-slate-900 shadow-sm backdrop-blur">
	<div class="mx-auto max-w-7xl px-4">
		<div class="flex h-[76px] items-center justify-between gap-6">
			<a href="/" class="shrink-0 rounded focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#e03420]">
				<img src="/images/2018/11/logo-sport-s.png" alt="Fitmus Sport" class="h-11 w-auto" />
			</a>

			<nav class="hidden items-center gap-1 lg:flex" aria-label="Primary navigation">
				<ul class="flex items-center gap-1">
					{primaryNav.slice(0, 2).map((item) => (
						<li>
							<a href={item.href} class={navLinkClasses}>
								{item.label}
							</a>
						</li>
					))}
					<li>
						<details class="group relative">
							<summary class={`${navLinkClasses} inline-flex cursor-pointer list-none items-center gap-2 [&::-webkit-details-marker]:hidden`}>
								<span>Fitmus Product</span>
								<svg class="menu-chevron size-3.5 shrink-0" viewBox="0 0 12 8" fill="none" aria-hidden="true">
									<path d="m1 1.5 5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
								</svg>
							</summary>
							<div class="absolute right-0 top-full z-50 mt-2 w-[560px] rounded-xl border border-slate-200 bg-white p-3 shadow-xl">
								<div class="mb-2 flex items-center justify-between border-b border-slate-100 px-3 pb-2">
									<span class="text-xs font-bold uppercase tracking-[0.12em] text-slate-500">Fitmus Product Categories</span>
									<a href="/fitmus-product/" class="text-xs font-semibold text-[#e03420] hover:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#e03420]">View all</a>
								</div>
								<ul class="grid grid-cols-2 gap-1">
									{categorySlugs.map((slug) => (
										<li>
											<a href={`/products/${slug}/`} class={submenuLinkClasses}>
												{categoryMap[slug]}
											</a>
										</li>
									))}
								</ul>
							</div>
						</details>
					</li>
					{primaryNav.slice(2).map((item) => (
						<li>
							<a href={item.href} class={navLinkClasses}>
								{item.label}
							</a>
						</li>
					))}
				</ul>
			</nav>

			<button
				type="button"
				class="inline-flex size-11 items-center justify-center rounded-lg text-slate-700 transition hover:bg-slate-100 hover:text-[#e03420] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#e03420] lg:hidden"
				data-mobile-menu-toggle
				aria-controls="mobile-primary-navigation"
				aria-expanded="false"
				aria-label="Open navigation menu"
			>
				<svg data-menu-icon class="size-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
				</svg>
				<svg data-close-icon class="hidden size-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path d="m6 6 12 12M18 6 6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
				</svg>
			</button>
		</div>

		<nav id="mobile-primary-navigation" class="hidden border-t border-slate-200 py-3 lg:hidden" aria-label="Mobile primary navigation">
			<div class="space-y-1">
				{primaryNav.slice(0, 2).map((item) => (
					<a href={item.href} class={`${navLinkClasses} block`}>
						{item.label}
					</a>
				))}

				<details class="group">
					<summary class={`${navLinkClasses} flex cursor-pointer list-none items-center justify-between [&::-webkit-details-marker]:hidden`}>
						<span>Fitmus Product</span>
						<svg class="menu-chevron size-3.5 shrink-0" viewBox="0 0 12 8" fill="none" aria-hidden="true">
							<path d="m1 1.5 5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
						</svg>
					</summary>
					<div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 p-2">
						<a href="/fitmus-product/" class={`${submenuLinkClasses} font-semibold text-[#e03420]`}>View Fitmus Product</a>
						<ul class="mt-1 space-y-1 border-t border-slate-200 pt-1">
							{categorySlugs.map((slug) => (
								<li>
									<a href={`/products/${slug}/`} class={submenuLinkClasses}>
										{categoryMap[slug]}
									</a>
								</li>
							))}
						</ul>
					</div>
				</details>

				{primaryNav.slice(2).map((item) => (
					<a href={item.href} class={`${navLinkClasses} block`}>
						{item.label}
					</a>
				))}
			</div>
		</nav>
	</div>
</header>

<script>
	const menuToggle = document.querySelector('[data-mobile-menu-toggle]');
	const mobileNavigation = document.getElementById('mobile-primary-navigation');

	if (menuToggle instanceof HTMLButtonElement && mobileNavigation) {
		const menuIcon = menuToggle.querySelector('[data-menu-icon]');
		const closeIcon = menuToggle.querySelector('[data-close-icon]');

		const setMobileMenu = (open: boolean) => {
			menuToggle.setAttribute('aria-expanded', String(open));
			menuToggle.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
			mobileNavigation.classList.toggle('hidden', !open);
			menuIcon?.classList.toggle('hidden', open);
			closeIcon?.classList.toggle('hidden', !open);
		};

		menuToggle.addEventListener('click', () => {
			setMobileMenu(menuToggle.getAttribute('aria-expanded') !== 'true');
		});

		mobileNavigation.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', () => setMobileMenu(false));
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && menuToggle.getAttribute('aria-expanded') === 'true') {
				setMobileMenu(false);
				menuToggle.focus();
			}
		});
	}
</script>

<style>
	.menu-chevron {
		transition: transform 160ms ease;
	}

	details[open] > summary .menu-chevron {
		transform: rotate(180deg);
	}
</style>
