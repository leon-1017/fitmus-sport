---
import { getCollection } from 'astro:content';

const products = await getCollection('products');

const categoryMap: Record<string, string> = {
  'weight-lifting-equipment': 'Weight Lifting Equipment',
  'body-weight-gymnastic': 'Body Weight & Gymnastic',
  'strength-condition': 'Strength & Condition',
  'crossfit-racks-rigs': 'Crossfit Racks & Rigs',
  'strongman-equipment': 'Strongman Equipment',
  'equipment-storage': 'Equipment Storage',
  'balance-mobility': 'Balance & Mobility',
  'cardio-equipment-accessories': 'Cardio Equipment & Accessories',
};

const categorySlugs = Object.keys(categoryMap);

const productsByCategory: Record<string, typeof products> = {};
for (const slug of categorySlugs) {
  productsByCategory[slug] = products
    .filter((p) => p.data.category === slug)
    .slice(0, 8);
}

const topNav = [
  { label: 'About Fitmus', href: '/about-fitmus/' },
  { label: 'Fitmus Product', href: '/fitmus-product/' },
  { label: 'In the News', href: '/in-the-news/' },
  { label: 'Contact Us', href: '/contact-us/' },
];

---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/95 text-slate-900 shadow-sm backdrop-blur">
	<div class="mx-auto max-w-7xl px-4">
		<div class="flex h-[76px] items-center justify-between gap-6">
			<a href="/" class="shrink-0 rounded focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#e03420]">
				<img src="/images/2018/11/logo-sport-s.png" alt="Fitmus Sport" class="h-11 w-auto" />
			</a>

			<nav class="hidden items-center gap-1 lg:flex" aria-label="Company navigation">
				{
					topNav.map((item) => (
						<a
							href={item.href}
							class="rounded px-3 py-2 text-sm font-semibold uppercase tracking-[0.08em] text-slate-700 transition hover:bg-slate-100 hover:text-[#e03420] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#e03420]"
						>
							{item.label}
						</a>
					))
				}
			</nav>
		</div>

		<nav class="-mx-4 border-t border-slate-200 lg:hidden" aria-label="Mobile company navigation">
			<div class="flex gap-1 overflow-x-auto px-4 py-2">
				<a
					href="/products/"
					class="shrink-0 rounded px-3 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 hover:text-[#e03420] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#e03420]"
				>
					Products
				</a>
				{
					topNav.map((item) => (
						<a
							href={item.href}
							class="shrink-0 rounded px-3 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 hover:text-[#e03420] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#e03420]"
						>
							{item.label}
						</a>
					))
				}
			</div>
		</nav>

		<nav class="-mx-4 hidden border-t border-slate-200 lg:block" aria-label="Product categories">
			<div class="overflow-x-auto px-4">
				<ul class="flex min-w-max items-center">
				{
					categorySlugs.map((slug) => {
						const items = productsByCategory[slug] || [];
						return (
							<li class="group relative">
								<a
									href={`/products/${slug}/`}
									class="block border-b-2 border-transparent px-4 py-3 text-sm font-semibold uppercase tracking-[0.04em] text-slate-700 transition hover:border-[#e03420] hover:bg-slate-50 hover:text-[#e03420] focus-visible:outline-2 focus-visible:outline-offset-[-2px] focus-visible:outline-[#e03420]"
								>
									{categoryMap[slug]}
								</a>
								<div class="absolute left-0 top-full z-50 hidden min-w-[280px] border border-slate-200 bg-white text-slate-800 shadow-xl group-hover:block group-focus-within:block">
									<ul class="py-2">
										{items.map((p) => (
											<li>
												<a
													href={`/product/${p.data.slug}/`}
													class="block truncate px-4 py-2 text-sm hover:bg-slate-100 hover:text-[#e03420] focus-visible:bg-slate-100 focus-visible:text-[#e03420] focus-visible:outline-none"
												>
													{p.data.title}
												</a>
											</li>
										))}
										<li>
											<a
												href={`/products/${slug}/`}
												class="block px-4 py-2 text-sm font-semibold text-[#e03420] hover:bg-slate-100 focus-visible:bg-slate-100 focus-visible:outline-none"
											>
												View All →
											</a>
										</li>
									</ul>
								</div>
							</li>
						);
					})
				}
			</ul>
			</div>
		</nav>
	</div>
</header>
