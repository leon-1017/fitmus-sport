---
import '../styles/global.css';

export interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	image?: string;
	layout?: 'default' | 'sidebar';
}

const { title, description, canonical, image, layout = 'default' } = Astro.props;
const siteTitle = title ? `${title} | Fitmus Sport` : 'Fitmus Sport';
const defaultDesc = 'Rizhao Fitmus Sporting Goods Co.Ltd - CrossFit, functional fitness and commercial gym equipment manufacturer.';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description || defaultDesc} />
		{canonical && <link rel="canonical" href={canonical} />}
		{image && <meta property="og:image" content={image} />}
		<title>{siteTitle}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Oxygen:wght@300;400;700&display=swap"
		/>
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
	</head>
	<body class="bg-white text-gray-800 font-['Oxygen','Helvetica','Arial',sans-serif]">
		<slot />
	</body>
</html>
