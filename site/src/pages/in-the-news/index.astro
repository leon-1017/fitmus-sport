---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import pages from '../../data/pages.json';
import { formatPostDate, sortPostsByDate } from '../../lib/news';

const page = pages.find((p: any) => p.slug === 'in-the-news') || {
	title: 'In the News',
	description: 'News, product updates and fitness insights from Fitmus Sport.',
};
const posts = sortPostsByDate(await getCollection('posts'));
const fallbackImage = '/images/2016/02/favicon-200.png';
---

<Layout title={page.title} description={page.description}>
	<Header />
	<main>
		<section class="bg-slate-950 px-4 py-16 text-white sm:px-6 lg:py-24" aria-labelledby="news-page-title">
			<div class="mx-auto max-w-7xl">
				<div class="max-w-3xl">
					<p class="text-sm font-semibold uppercase tracking-[0.24em] text-[#ff6b56]">Fitmus journal</p>
					<h1 id="news-page-title" class="mt-4 text-4xl font-bold tracking-tight sm:text-5xl">{page.title}</h1>
					<p class="mt-5 max-w-2xl text-base leading-7 text-slate-300 sm:text-lg">{page.description}</p>
				</div>
				<div class="mt-10 flex flex-wrap gap-4 text-sm text-slate-300" aria-label="News summary">
					<span class="rounded-full border border-white/20 px-4 py-2">{posts.length} articles</span>
					<span class="rounded-full border border-white/20 px-4 py-2">Updated regularly</span>
				</div>
			</div>
		</section>

		<section class="bg-slate-50 px-4 py-14 sm:px-6 lg:py-20" aria-labelledby="news-list-title">
			<div class="mx-auto max-w-7xl">
				<div class="mb-9 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
					<div>
						<p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#e03420]">Latest stories</p>
						<h2 id="news-list-title" class="mt-2 text-3xl font-bold tracking-tight text-slate-950 sm:text-4xl">Ideas for better training spaces</h2>
					</div>
					<p class="max-w-md text-sm leading-6 text-slate-600">Browse product news, training guidance and practical insights from the Fitmus team.</p>
				</div>

				<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
					{posts.map((post) => {
						const image = post.data.featuredImage || fallbackImage;
						const excerpt = post.data.seoDescription || 'Read the latest Fitmus Sport news and fitness equipment insights.';
						const date = formatPostDate(post.data.date);
						return (
							<article class="group flex h-full flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
								<a href={`/${post.id}/`} class="block overflow-hidden focus:outline-none focus-visible:ring-4 focus-visible:ring-[#e03420]/30" aria-label={`Read ${post.data.title}`}>
									<div class="aspect-[16/9] overflow-hidden bg-slate-100">
										<img src={image} alt={post.data.title} class="h-full w-full object-cover transition duration-500 group-hover:scale-105" loading="lazy" />
									</div>
								</a>
								<div class="flex flex-1 flex-col p-5 sm:p-6">
									{date && <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">{date}</p>}
									<h3 class="mt-3 text-xl font-bold leading-snug text-slate-950"><a href={`/${post.id}/`} class="rounded-sm hover:text-[#e03420] focus:outline-none focus-visible:ring-4 focus-visible:ring-[#e03420]/30">{post.data.title}</a></h3>
									<p class="mt-3 line-clamp-3 text-sm leading-6 text-slate-600">{excerpt}</p>
									<div class="mt-auto pt-5"><a href={`/${post.id}/`} class="inline-flex items-center gap-2 text-sm font-bold text-[#e03420] hover:text-[#b82718] focus:outline-none focus-visible:ring-4 focus-visible:ring-[#e03420]/30">Read story <span aria-hidden="true">→</span></a></div>
								</div>
							</article>
						);
					})}
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
