---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProductGallery from '../../components/ProductGallery.astro';
import RelatedProducts from '../../components/RelatedProducts.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const products = await getCollection('products');
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const imageUrl = Astro.site && entry.data.featuredImage
  ? new URL(entry.data.featuredImage, Astro.site).href
  : undefined;
const productSchema = canonicalUrl
  ? {
      '@context': 'https://schema.org',
      '@type': 'Product',
      '@id': canonicalUrl,
      name: entry.data.title,
      description: entry.data.seoDescription || entry.data.title,
      image: imageUrl,
      brand: { '@type': 'Brand', name: 'Fitmus' },
      manufacturer: { '@type': 'Organization', name: 'Rizhao Fitmus Sporting Goods Co.Ltd' },
    }
  : undefined;
const categoryMap: Record<string, string> = {
  'weight-lifting-equipment': 'Weight Lifting Equipment',
  'body-weight-gymnastic': 'Body Weight & Gymnastic',
  'strength-condition': 'Strength & Condition',
  'crossfit-racks-rigs': 'Crossfit Racks & Rigs',
  'strongman-equipment': 'Strongman Equipment',
  'equipment-storage': 'Equipment Storage',
  'balance-mobility': 'Balance & Mobility',
  'cardio-equipment-accessories': 'Cardio Equipment & Accessories',
};
---

<Layout title={entry.data.title} description={entry.data.seoDescription} image={entry.data.featuredImage}>
	{productSchema && <script type="application/ld+json" set:html={JSON.stringify(productSchema).replace(/</g, '\\u003c')} />}
	<Header />
	<main class="bg-slate-50 px-4 py-8 sm:px-6 lg:py-12">
		<div class="mx-auto max-w-7xl">
			<nav class="mb-7 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-slate-500" aria-label="Breadcrumb">
					<a href="/" class="hover:text-[#e03420]">Home</a>
					<span aria-hidden="true">/</span>
					{
						entry.data.category && (
							<>
								<a href={`/products/${entry.data.category}/`} class="hover:text-[#e03420]">
									{categoryMap[entry.data.category] || entry.data.category}
								</a>
								<span aria-hidden="true">/</span>
							</>
						)
					}
				<span class="max-w-full break-words text-slate-800" aria-current="page">{entry.data.title}</span>
			</nav>

			<div class="grid min-w-0 gap-8 lg:grid-cols-[minmax(0,1.35fr)_minmax(280px,0.65fr)] lg:items-start lg:gap-12">
				<article class="min-w-0 rounded-3xl border border-slate-200 bg-white p-5 shadow-sm sm:p-8">
					<header class="border-b border-slate-200 pb-6">
						{entry.data.category && <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#e03420]">{categoryMap[entry.data.category] || entry.data.category}</p>}
						<h1 class="mt-3 break-words text-3xl font-bold leading-tight tracking-tight text-slate-950 sm:text-4xl">{entry.data.title}</h1>
						{entry.data.seoDescription && <p class="mt-4 max-w-3xl text-base leading-7 text-slate-600">{entry.data.seoDescription}</p>}
					</header>

					<div class="pt-7">
						<ProductGallery images={entry.data.gallery.length ? entry.data.gallery : (entry.data.featuredImage ? [entry.data.featuredImage] : [])} title={entry.data.title} />
						<div class="product-content prose prose-slate max-w-none">
							<Content />
						</div>
					</div>

					<RelatedProducts products={products} currentSlug={entry.id} category={entry.data.category} />
				</article>

				<aside class="space-y-6 lg:sticky lg:top-6">
					<section class="rounded-3xl bg-slate-950 p-6 text-white sm:p-7" aria-labelledby="product-help-title">
						<p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#ff6b56]">Fitmus support</p>
						<h2 id="product-help-title" class="mt-3 text-2xl font-bold">Need a complete equipment package?</h2>
						<p class="mt-4 text-sm leading-6 text-slate-300">Tell us about your facility, target products or OEM requirements and our team can help you plan the next step.</p>
						<a href="/contact-us/" class="mt-6 inline-flex w-full items-center justify-center rounded-full bg-[#e03420] px-5 py-3 text-sm font-bold text-white transition hover:bg-[#b82718] focus:outline-none focus-visible:ring-4 focus-visible:ring-[#e03420]/40">Contact Fitmus <span class="ml-2" aria-hidden="true">→</span></a>
					</section>

					<section class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-7" aria-labelledby="product-categories-title">
						<h2 id="product-categories-title" class="text-lg font-bold text-slate-950">Explore product categories</h2>
						<ul class="mt-4 divide-y divide-slate-100">
							{Object.entries(categoryMap).map(([slug, label]) => (
								<li><a href={`/products/${slug}/`} class="flex items-center justify-between gap-3 py-3 text-sm text-slate-700 transition hover:text-[#e03420]"><span>{label}</span><span aria-hidden="true">→</span></a></li>
							))}
						</ul>
					</section>
				</aside>
			</div>
		</div>
	</main>
	<Footer />
</Layout>

<style is:global>
	.product-content img {
		height: auto;
		max-width: 100%;
	}
	.product-content {
		min-width: 0;
		overflow-wrap: anywhere;
	}
	.product-content iframe,
	.product-content video {
		display: block;
		max-width: 100%;
		width: 100%;
		aspect-ratio: 16 / 9;
	}
	.product-content table {
		display: block;
		max-width: 100%;
		overflow-x: auto;
	}
	.product-content [style*="width"] {
		max-width: 100% !important;
	}
	.product-content .fusion-fullwidth,
	.product-content .fusion-builder-row,
	.product-content .fusion-layout-column,
	.product-content .fusion-column-wrapper {
		box-sizing: border-box;
		max-width: 100% !important;
		width: auto !important;
		margin-left: 0 !important;
		margin-right: 0 !important;
		padding-left: 0 !important;
		padding-right: 0 !important;
	}
	.product-content .fusion-builder-row {
		display: block !important;
	}
	.product-content .fusion-clearfix,
	.product-content .fusion-sep-clear {
		height: 0 !important;
		clear: both;
	}
</style>
