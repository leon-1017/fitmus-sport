---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Sidebar from '../../components/Sidebar.astro';
import Share from '../../components/Share.astro';
import ProductGallery from '../../components/ProductGallery.astro';
import RelatedProducts from '../../components/RelatedProducts.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const products = await getCollection('products');
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const imageUrl = Astro.site && entry.data.featuredImage
  ? new URL(entry.data.featuredImage, Astro.site).href
  : undefined;
const productSchema = canonicalUrl
  ? {
      '@context': 'https://schema.org',
      '@type': 'Product',
      '@id': canonicalUrl,
      name: entry.data.title,
      description: entry.data.seoDescription || entry.data.title,
      image: imageUrl,
      brand: { '@type': 'Brand', name: 'Fitmus' },
      manufacturer: { '@type': 'Organization', name: 'Rizhao Fitmus Sporting Goods Co.Ltd' },
    }
  : undefined;
const categoryMap: Record<string, string> = {
  'weight-lifting-equipment': 'Weight Lifting Equipment',
  'body-weight-gymnastic': 'Body Weight & Gymnastic',
  'strength-condition': 'Strength & Condition',
  'crossfit-racks-rigs': 'Crossfit Racks & Rigs',
  'strongman-equipment': 'Strongman Equipment',
  'equipment-storage': 'Equipment Storage',
  'balance-mobility': 'Balance & Mobility',
  'cardio-equipment-accessories': 'Cardio Equipment & Accessories',
};
---

<Layout title={entry.data.title} description={entry.data.seoDescription} image={entry.data.featuredImage}>
	{productSchema && <script type="application/ld+json" set:html={JSON.stringify(productSchema).replace(/</g, '\\u003c')} />}
	<Header />
	<main class="max-w-7xl mx-auto px-4 py-10">
		<div class="grid lg:grid-cols-3 gap-10">
			<div class="lg:col-span-2">
				<nav class="text-sm text-gray-500 mb-4">
					<a href="/" class="hover:text-[#e03420]">Home</a>
					<span class="mx-2">/</span>
					{
						entry.data.category && (
							<>
								<a href={`/products/${entry.data.category}/`} class="hover:text-[#e03420]">
									{categoryMap[entry.data.category] || entry.data.category}
								</a>
								<span class="mx-2">/</span>
							</>
						)
					}
					<span class="text-gray-800">{entry.data.title}</span>
				</nav>

				<h1 class="text-3xl font-bold text-gray-900 mb-6">{entry.data.title}</h1>


				<ProductGallery images={entry.data.gallery.length ? entry.data.gallery : (entry.data.featuredImage ? [entry.data.featuredImage] : [])} title={entry.data.title} />

				<div class="product-content prose max-w-none">
					<Content />
				</div>

				<Share title={entry.data.title} />
				<RelatedProducts products={products} currentSlug={entry.id} category={entry.data.category} />
			</div>

			<div class="lg:col-span-1">
				<Sidebar />
			</div>
		</div>
	</main>
	<Footer />
</Layout>

<style is:global>
	.product-content img {
		height: auto;
		max-width: 100%;
	}
</style>
