---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import Share from '../components/Share.astro';
import ArticleDiscovery from '../components/ArticleDiscovery.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const date = entry.data.date ? new Date(entry.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const imageUrl = Astro.site && entry.data.featuredImage
  ? new URL(entry.data.featuredImage, Astro.site).href
  : undefined;
const articleSchema = canonicalUrl
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      '@id': canonicalUrl,
      headline: entry.data.title,
      description: entry.data.seoDescription || entry.data.title,
      mainEntityOfPage: canonicalUrl,
      image: imageUrl,
      ...(entry.data.date ? { datePublished: entry.data.date } : {}),
      author: { '@type': 'Organization', name: 'Fitmus Sport' },
      publisher: { '@type': 'Organization', name: 'Fitmus Sport' },
    }
  : undefined;
---

<Layout title={entry.data.title} description={entry.data.seoDescription} image={entry.data.featuredImage} type="article">
	{articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema).replace(/</g, '\\u003c')} />}
	<Header />
	<main class="max-w-7xl mx-auto px-4 py-10">
		<div class="grid lg:grid-cols-3 gap-10">
			<article class="lg:col-span-2">
				<nav class="text-sm text-gray-500 mb-4">
					<a href="/" class="hover:text-[#e03420]">Home</a>
					<span class="mx-2">/</span>
					<a href="/in-the-news/" class="hover:text-[#e03420]">In the News</a>
					<span class="mx-2">/</span>
					<span class="text-gray-800">{entry.data.title}</span>
				</nav>

				<h1 class="text-3xl font-bold text-gray-900 mb-2">{entry.data.title}</h1>
				{date && <p class="text-sm text-gray-500 mb-6">{date}</p>}

				{
					entry.data.featuredImage && (
						<div class="mb-8 rounded overflow-hidden border border-gray-200">
							<img src={entry.data.featuredImage} alt={entry.data.title} class="w-full h-auto" />
						</div>
					)
				}

				<div class="post-content prose max-w-none">
					<Content />
				</div>

				<Share title={entry.data.title} />
			</article>

			<div class="lg:col-span-1">
				<ArticleDiscovery currentSlug={entry.id} />
				<Sidebar />
			</div>
		</div>
	</main>
	<Footer />
</Layout>

<style is:global>
	.post-content img {
		height: auto;
		max-width: 100%;
	}
</style>
