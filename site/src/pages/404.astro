---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
	title="Page Not Found"
	description="The requested Fitmus Sport page could not be found."
	noindex={true}
>
	<Header />
	<main class="max-w-3xl mx-auto px-6 py-24 text-center">
		<p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#e03420]">404</p>
		<h1 class="mt-4 text-4xl font-bold text-gray-900">Page not found</h1>
		<p class="mt-5 text-gray-600">
			The page you requested is unavailable or has moved. Browse our product catalogue or return home.
		</p>
		<div class="mt-8 flex flex-wrap justify-center gap-4">
			<a href="/" class="rounded bg-[#e03420] px-5 py-3 font-semibold text-white hover:bg-[#c0291b]">Home</a>
			<a href="/fitmus-product/" class="rounded border border-gray-300 px-5 py-3 font-semibold text-gray-800 hover:border-[#e03420] hover:text-[#e03420]">
				Browse products
			</a>
		</div>
	</main>
	<Footer />
</Layout>
