---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Highlights from '../components/Highlights.astro';
import DiverseProductChain from '../components/DiverseProductChain.astro';
import HomepageSupport from '../components/HomepageSupport.astro';
import FeaturedProducts from '../components/FeaturedProducts.astro';
import ProfessionalSection from '../components/ProfessionalSection.astro';
import ReadyForNew from '../components/ReadyForNew.astro';
import LatestProducts from '../components/LatestProducts.astro';
import Footer from '../components/Footer.astro';
---

<Layout
	title="Crossfit Gym Equipment | Functional Fitness Equipment | Fitness Factory"
	description="Full Effort is Full Victory! Equipment for Crossfit, Functional Training and Commercial Gym."
>
	<div class="flex min-h-screen flex-col">
		<Header />
		<main class="flex-1 min-w-0">
			<Hero
				title="Equipment for Crossfit | Functional Training | Commercial Gym"
				subtitle="Full Effort is Full Victory!"
			/>
			<Highlights />
			<DiverseProductChain />
			<HomepageSupport />
			<FeaturedProducts />
			<ProfessionalSection />
			<ReadyForNew />
			<LatestProducts />
		</main>
		<Footer />
	</div>
</Layout>
