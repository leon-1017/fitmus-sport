---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import pages from '../../data/pages.json';

const page = pages.find((p: any) => p.slug === 'contact-us') || {
	title: 'Contact Us',
	description: 'Contact Fitmus Sport for fitness equipment, product support and OEM enquiries.',
};
const address = 'Wulian County Industrial Area, Rizhao, 262300, Shandong Province, China';
const mapsUrl = 'https://www.google.com/maps/search/?api=1&query=Wulian+County+Industrial+Area%2C+Rizhao%2C+Shandong%2C+China';
---

<Layout title={page.title} description={page.description}>
	<Header />
	<main>
		<section class="relative overflow-hidden bg-slate-950 px-4 py-16 text-white sm:px-6 lg:py-24" aria-labelledby="contact-page-title">
			<div class="absolute inset-0 bg-[url('/images/2016/04/Background-1.jpg')] bg-cover bg-center opacity-20" aria-hidden="true"></div>
			<div class="relative mx-auto max-w-7xl">
				<div class="max-w-3xl">
					<p class="text-sm font-semibold uppercase tracking-[0.24em] text-[#ff6b56]">Fitmus Sport</p>
					<h1 id="contact-page-title" class="mt-4 text-4xl font-bold tracking-tight sm:text-5xl">{page.title}</h1>
					<p class="mt-5 max-w-2xl text-base leading-7 text-slate-200 sm:text-lg">{page.description}</p>
				</div>
			</div>
		</section>

		<section class="bg-white px-4 py-14 sm:px-6 lg:py-20" aria-labelledby="contact-intro-title">
			<div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(320px,0.72fr)] lg:items-start">
				<div>
					<p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#e03420]">A reliable partner</p>
					<h2 id="contact-intro-title" class="mt-3 text-3xl font-bold tracking-tight text-slate-950 sm:text-4xl">Let’s build a stronger training space</h2>
					<div class="mt-6 space-y-4 text-base leading-8 text-slate-600">
						<p>At Fitmus, we believe fitness equipment should feel strong, comfortable and dependable. That same standard guides the way we work with every customer.</p>
						<p>Whether you are equipping a commercial gym, building a CrossFit box or sourcing products for retail, our team can help you find a practical equipment mix and discuss custom requirements.</p>
					</div>
					<div class="mt-8 flex items-center gap-4 rounded-2xl border border-slate-200 bg-slate-50 p-5">
						<img src="/images/2018/11/logo-sport-s.png" alt="Fitmus Sport" class="h-auto w-36" loading="lazy" />
						<p class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-500">Be strong</p>
					</div>
				</div>

				<aside class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-8" aria-labelledby="contact-details-title">
					<h2 id="contact-details-title" class="text-2xl font-bold text-slate-950">Contact details</h2>
					<dl class="mt-6 space-y-5 text-sm">
						<div>
							<dt class="font-semibold uppercase tracking-[0.14em] text-slate-500">Address</dt>
							<dd class="mt-2 leading-6 text-slate-700">Rizhao, Shandong, China<br />{address}</dd>
						</div>
						<div>
							<dt class="font-semibold uppercase tracking-[0.14em] text-slate-500">Phone</dt>
							<dd class="mt-2 font-semibold text-slate-800">+86 159 6309 7328</dd>
						</div>
						<div>
							<dt class="font-semibold uppercase tracking-[0.14em] text-slate-500">Email</dt>
							<dd class="mt-2 font-semibold text-slate-800">info@fitmus-sport.com</dd>
						</div>
						<div>
							<dt class="font-semibold uppercase tracking-[0.14em] text-slate-500">Working hours</dt>
							<dd class="mt-2 leading-6 text-slate-700">Monday–Friday: 8:30 am–6:00 pm<br />Saturday: 9:00 am–2:00 pm</dd>
						</div>
					</dl>
					<a href={mapsUrl} target="_blank" rel="noreferrer" class="mt-7 inline-flex w-full items-center justify-center rounded-full bg-[#e03420] px-5 py-3 text-sm font-bold text-white transition hover:bg-[#b82718] focus:outline-none focus-visible:ring-4 focus-visible:ring-[#e03420]/30">Open location in Maps <span class="ml-2" aria-hidden="true">↗</span></a>
				</aside>
			</div>
		</section>

		<section class="bg-slate-50 px-4 py-14 sm:px-6 lg:py-20" aria-labelledby="contact-next-title">
			<div class="mx-auto max-w-7xl rounded-3xl bg-[#e03420] px-6 py-10 text-white sm:px-10 lg:flex lg:items-center lg:justify-between lg:gap-8">
				<div>
					<p class="text-sm font-semibold uppercase tracking-[0.2em] text-white/75">Ready when you are</p>
					<h2 id="contact-next-title" class="mt-2 text-2xl font-bold sm:text-3xl">Explore the Fitmus product range</h2>
				</div>
				<a href="/fitmus-product/" class="mt-6 inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-bold text-slate-950 transition hover:bg-slate-100 focus:outline-none focus-visible:ring-4 focus-visible:ring-white/50 lg:mt-0">View products <span class="ml-2" aria-hidden="true">→</span></a>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
