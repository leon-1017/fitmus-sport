---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageContent from '../../components/PageContent.astro';
import pages from '../../data/pages.json';

const page = pages.find((p: any) => p.slug === 'contact-us') || { title: 'Contact Us', bodyHtml: '' };
---

<Layout title={page.title} description={page.description}>
	<Header />
	<main>
		<PageContent title={page.title} description={page.description} bodyHtml={page.bodyHtml} />
		<section class="mx-auto max-w-7xl px-6 pb-16" aria-labelledby="location-heading">
			<div class="grid gap-6 rounded-2xl border border-slate-200 bg-slate-50 p-6 md:grid-cols-[1fr_auto] md:items-center md:p-8">
				<div>
					<p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#e03420]">Visit Fitmus</p>
					<h2 id="location-heading" class="mt-2 text-2xl font-bold text-slate-900">Rizhao, Shandong, China</h2>
					<p class="mt-3 max-w-2xl leading-7 text-slate-600">Wulian County Industrial Area, Rizhao, 262300, Shandong Province, China.</p>
					<div class="mt-4 flex flex-wrap gap-x-5 gap-y-2 text-sm text-slate-700">
						<a class="hover:text-[#e03420]" href="tel:+8615963097328">Tel: +86 159 6309 7328</a>
						<a class="hover:text-[#e03420]" href="mailto:info@fitmus-sport.com">info@fitmus-sport.com</a>
					</div>
				</div>
				<a href="https://www.google.com/maps/search/?api=1&query=Wulian+County+Industrial+Area%2C+Rizhao%2C+Shandong%2C+China" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-800 hover:border-[#e03420] hover:text-[#e03420] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#e03420]">Open in Maps <span class="ml-2" aria-hidden="true">↗</span></a>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
